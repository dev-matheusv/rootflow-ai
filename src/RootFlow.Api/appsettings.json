{
  "AI": {
    "Mode": "OpenAI"
  },
  "Jwt": {
    "Issuer": "RootFlow",
    "Audience": "RootFlow.Web",
    "ExpiresInMinutes": 480
  },
  "Storage": {
    "RootPath": "storage"
  },
  "Chunking": {
    "ChunkSize": 1200,
    "ChunkOverlap": 200
  },
  "OpenAI": {
    "BaseUrl": "https://api.openai.com/v1/",
    "ChatModel": "gpt-4.1-mini",
    "EmbeddingModel": "text-embedding-3-small"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
