{
  "AI": {
    "Mode": "OpenAI"
  },
  "Jwt": {
    "Issuer": "RootFlow",
    "Audience": "RootFlow.Web",
    "ExpiresInMinutes": 480
  },
  "Storage": {
    "RootPath": "storage"
  },
  "Chunking": {
    "ChunkSize": 1200,
    "ChunkOverlap": 200
  },
  "PasswordReset": {
    "FrontendBaseUrl": ""
  },
  "WorkspaceInvitations": {
    "FrontendBaseUrl": ""
  },
  "EmailDelivery": {
    "FromName": "RootFlow",
    "SmtpPort": 587,
    "SmtpEnableSsl": true
  },
  "OpenAI": {
    "BaseUrl": "https://api.openai.com/v1/",
    "ChatModel": "gpt-4.1-mini",
    "EmbeddingModel": "text-embedding-3-small"
  },
  "Billing": {
    "DefaultPlanCode": "starter",
    "DefaultSubscriptionPeriodDays": 30,
    "MinimumAssistantCreditsRequired": 1,
    "CreditsPerDollar": 100,
    "DefaultPromptCostPerMillionTokens": 0.4,
    "DefaultCompletionCostPerMillionTokens": 1.6,
    "Models": [
      {
        "Provider": "openai",
        "Model": "gpt-4.1-mini",
        "PromptCostPerMillionTokens": 0.4,
        "CompletionCostPerMillionTokens": 1.6
      },
      {
        "Provider": "fake",
        "Model": "fake-chat-premium-v1",
        "PromptCostPerMillionTokens": 0.0,
        "CompletionCostPerMillionTokens": 0.0
      },
      {
        "Provider": "fake",
        "Model": "fake-chat-deterministic-v1",
        "PromptCostPerMillionTokens": 0.0,
        "CompletionCostPerMillionTokens": 0.0
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
