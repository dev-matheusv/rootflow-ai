# RootFlow backend runtime environment reference
#
# ASP.NET Core does not load .env files automatically by default.
# Use these keys in your deploy target, shell session, or launch profile.

# Required for OpenAI mode.
OPENAI_API_KEY=your-openai-api-key

# Required in all environments. Use a long random secret in production.
ROOTFLOW_JWT_KEY=replace-with-a-long-random-secret

# Primary PostgreSQL connection string option.
# For local development with docker compose:
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=rootflow;Username=postgres;Password=postgres

# Optional deploy-target alternatives. RootFlow will prefer these over
# ConnectionStrings__Postgres when present and will normalize postgres:// URLs.
# ROOTFLOW_DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Required for browser clients outside local development.
ROOTFLOW_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Required whenever the API needs to generate browser-facing links in email.
# Example production value: https://app.your-rootflow-domain.com
ROOTFLOW_FRONTEND_BASE_URL=http://localhost:5173

# Optional outbound email configuration.
# When these values are absent, RootFlow keeps the current safe logging fallback
# in local development and warns instead of sending email in other environments.
ROOTFLOW_EMAIL_FROM_NAME=RootFlow
# ROOTFLOW_EMAIL_FROM_ADDRESS=notifications@your-rootflow-domain.com
# ROOTFLOW_EMAIL_SMTP_HOST=smtp.your-provider.com
# ROOTFLOW_EMAIL_SMTP_PORT=587
# ROOTFLOW_EMAIL_SMTP_USERNAME=your-smtp-username
# ROOTFLOW_EMAIL_SMTP_PASSWORD=your-smtp-password
# ROOTFLOW_EMAIL_SMTP_ENABLE_SSL=true
# ROOTFLOW_EMAIL_SMTP_TIMEOUT_MS=15000
#
# Gmail example:
# ROOTFLOW_EMAIL_FROM_ADDRESS=your.name@gmail.com
# ROOTFLOW_EMAIL_SMTP_HOST=smtp.gmail.com
# ROOTFLOW_EMAIL_SMTP_PORT=587
# ROOTFLOW_EMAIL_SMTP_USERNAME=your.name@gmail.com
# ROOTFLOW_EMAIL_SMTP_PASSWORD=your-16-character-app-password
# ROOTFLOW_EMAIL_SMTP_ENABLE_SSL=true

# Optional overrides.
AI__Mode=OpenAI
OpenAI__BaseUrl=https://api.openai.com/v1/
OpenAI__ChatModel=gpt-4.1-mini
OpenAI__EmbeddingModel=text-embedding-3-small
