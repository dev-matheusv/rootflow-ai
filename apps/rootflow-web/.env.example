# RootFlow Web environment variables
#
# Copy this file to .env.local for local development.
# VITE_API_BASE_URL is required. The frontend no longer guesses a localhost API.

# Recommended local backend target when running:
# dotnet run --project src/RootFlow.Api --launch-profile http
VITE_API_BASE_URL=http://localhost:5011

# If you intentionally run the backend HTTPS profile instead, use:
# VITE_API_BASE_URL=https://localhost:7088

# Example production value:
# VITE_API_BASE_URL=https://api.your-rootflow-domain.com
